# ==========================================
# FREEFLOW MEDIA - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to git!

# ==========================================
# EMAILJS (Fallback for contact form)
# ==========================================
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# ==========================================
# FIREBASE
# ==========================================
# Firebase config is in src/firebase/config.js
# Make sure to set up Firebase secrets for Cloud Functions:
# firebase functions:secrets:set GEMINI_API_KEY
# firebase functions:secrets:set SENDGRID_API_KEY
# firebase functions:secrets:set SLACK_WEBHOOK_URL
# firebase functions:secrets:set APIFY_API_KEY

# ==========================================
# N8N AUTOMATION
# ==========================================
# Replace with your production n8n URL
# Leave empty if not using n8n (Firebase will handle everything)
VITE_N8N_WEBHOOK_URL=https://your-n8n-domain.com/webhook/freeflow-lead

# ==========================================
# SENDGRID (Email delivery)
# ==========================================
# Used by Firebase Functions for email automation
# Set as Firebase secret, not here
# SENDGRID_API_KEY=sg.xxxxxxxxxxxxxxxxxxxxx

# ==========================================
# SLACK NOTIFICATIONS
# ==========================================
# Webhook URL for Slack notifications
# Set as Firebase secret, not here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==========================================
# GOOGLE GEMINI API
# ==========================================
# Used by Firebase Functions for AI generation
# Set as Firebase secret, not here
# GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# APIFY (Lead enrichment)
# ==========================================
# Set as Firebase secret, not here
# APIFY_API_KEY=apify_xxxxxxxxxxxxxxxxxxxxx

# ==========================================
# YOCO PAYMENT GATEWAY
# ==========================================
# Yoco public key for payment processing
VITE_YOCO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# ==========================================
# BUFFER API (Social media scheduling)
# ==========================================
# Set as Firebase secret, not here
# BUFFER_API_KEY=your_buffer_api_key

# ==========================================
# GOOGLE REVIEW LINK
# ==========================================
# Your actual Google review page URL
VITE_GOOGLE_REVIEW_URL=https://g.page/r/YOUR_REVIEW_LINK

# ==========================================
# APPLICATION URL
# ==========================================
VITE_APP_URL=http://localhost:5173
# Production: https://freeflow-media.web.app
