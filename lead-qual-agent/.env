# ==========================================
# FREEFLOW MEDIA - LEAD QUALIFICATION AGENT
# Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to git!

# ==========================================
# GEMINI AI (Required)
# ==========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDmBJhZzJiFJAWkYhJ3zNxIsAl_QUMb29k

# Gemini model (optional, defaults to gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.5-pro

# ==========================================
# FIREBASE (Required for production)
# ==========================================
# Option 1: Service Account JSON file path
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Option 2: For Cloud Functions, leave blank (uses default credentials)
# FIREBASE_SERVICE_ACCOUNT_PATH=

# ==========================================
# TWILIO / WHATSAPP (Required for high-value lead alerts)
# ==========================================
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Twilio WhatsApp number (default is Twilio sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Sales team WhatsApp number (receives high-value lead alerts)
SALES_TEAM_WHATSAPP=whatsapp:+27123456789

# ==========================================
# LANGSMITH (Optional - for observability)
# ==========================================
# Get from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=freeflow-media-lead-qual

# ==========================================
# LOGGING (Optional)
# ==========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==========================================
# SERVER (Optional)
# ==========================================
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://freeflow-media.web.app

# ==========================================
# ENVIRONMENT
# ==========================================
# Environment: development, staging, production
ENVIRONMENT=development
